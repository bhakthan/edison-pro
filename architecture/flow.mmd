flowchart LR
    subgraph Clients["Clients & Entry Points"]
        ReactUI["React UI<br/>Vite + TypeScript<br/>Upload / Chat / Templates / Innovative / Flickering / Dynamic Agents"]
        GradioUI["Gradio UI<br/>edisonpro_ui.py"]
        CLI["CLI<br/>edisonpro.py"]
        BlobInput["Azure Blob Storage<br/>optional input/output"]
        ReactUI --> FastAPI
        GradioUI --> FastAPI
        CLI --> Orchestrator
        BlobInput -.-> CLI
    end

    subgraph API["FastAPI Application"]
        FastAPI["api.py / api_server.py"]
        UploadAPI["Upload & Ask<br/>/upload /ask /documents"]
        TemplateAPI["Templates<br/>/templates /templates/execute"]
        FeatureAPI["Innovative + Flickering + PID<br/>/predict-anomalies /expert-review /analyze/flickering /upload/pid"]
        DynamicAPI["Dynamic Agents<br/>/dynamic-agents/status /ensure /run /lineage"]
        ResultsAPI["Results + Downloads<br/>/generate-results /results/latest /download/*"]
        FastAPI --> UploadAPI
        FastAPI --> TemplateAPI
        FastAPI --> FeatureAPI
        FastAPI --> DynamicAPI
        FastAPI --> ResultsAPI
    end

    subgraph Core["Document Understanding Pipeline"]
        Orchestrator["DiagramAnalysisOrchestratorPro"]
        Planner["PlanningAgentPro<br/>gpt-5-pro via Responses API<br/>domain + complexity + strategy"]
        Preprocessor["DocumentPreprocessorPro<br/>chunking + metadata + page structure"]
        ADI["Azure Document Intelligence<br/>layout / OCR / tables / title blocks"]
        Fallbacks["Fallback extraction<br/>MarkItDown / PyMuPDF / image-first handling"]
        Visual["VisualElementExtractorPro<br/>vision-based component and symbol extraction"]
        RustNative["Rust Native Subsystem<br/>parallel image handling<br/>chunk analytics<br/>cross-sheet graph<br/>rule-based anomaly detection"]
        Context["ContextManagerPro<br/>chunk staging + retrieval context"]
        Search["Azure AI Search<br/>hybrid vector + keyword index"]
        NativeInsights["Native Insights Payload<br/>cross-sheet graph + anomaly summary + connector hubs"]
        Orchestrator --> Planner
        Planner --> Preprocessor
        Preprocessor --> ADI
        ADI --> Visual
        ADI -.-> Fallbacks
        Fallbacks --> Visual
        Visual --> RustNative
        RustNative --> Context
        Context --> Search
        RustNative --> NativeInsights
    end

    subgraph Memory["Learning & Retrieval"]
        MemoryAtlas["Memory Atlas<br/>pattern memory + embeddings + novelty recall"]
        FlickeringSystem["Flickering System<br/>6-agent cognitive loop<br/>reality vs memory oscillation"]
        Feedback["Feedback + Analytics + Reports<br/>effectiveness tracking and HTML report generation"]
        Search <--> MemoryAtlas
        FlickeringSystem <--> MemoryAtlas
        FlickeringSystem --> Feedback
    end

    subgraph Interaction["Reasoning & Agent Layer"]
        Router["Question Router<br/>understanding vs data/agentic task"]
        GPTHandler["gpt-5-pro Handler<br/>engineering understanding<br/>reasoning + evidence"]
        CodeAgent["Azure AI Projects Code Agent<br/>GPT-5.4 + code interpreter<br/>tables / charts / files / calculations"]
        DynamicRegistry["DynamicMetaAgentRegistry<br/>persistent registry + lineage + evaluation + refinement"]
        DynamicStudio["Dynamic Agent Studio<br/>autonomous ensure/create/run"]
        TemplateRunner["Template execution<br/>guided multi-question workflows"]
        UploadAPI --> Orchestrator
        TemplateAPI --> TemplateRunner
        TemplateRunner --> Router
        UploadAPI --> Router
        Router --> GPTHandler
        Router --> CodeAgent
        CodeAgent -.->|agentic fallback| DynamicRegistry
        DynamicAPI --> DynamicStudio
        DynamicStudio --> DynamicRegistry
        DynamicRegistry --> CodeAgent
        GPTHandler --> Search
    end

    subgraph Outputs["Outputs & Demo Surfaces"]
        ChatOutput["Chat answers<br/>reasoning + evidence"]
        DataOutput["Tables / charts / CSV / Excel / downloadable files"]
        UploadReview["Upload review panels<br/>native graph + anomaly focus + failure-type drill-in"]
        ResultsPage["Comprehensive HTML results page<br/>persisted light/dark theme"]
        Reports["Innovative feature reports<br/>anomaly / expert review / visual summaries"]
        GPTHandler --> ChatOutput
        CodeAgent --> DataOutput
        NativeInsights --> UploadReview
        ResultsAPI --> ResultsPage
        Feedback --> Reports
    end

    FeatureAPI --> FlickeringSystem
    FeatureAPI --> Reports
    FeatureAPI --> Orchestrator
    ReactUI -.->|theme + interactive graph UX| UploadReview
    BlobInput -.-> ResultsPage

