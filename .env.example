AZURE_OPENAI_ENDPOINT=https://{your-custom-endpoint}.openai.azure.com/
AZURE_OPENAI_API_KEY={your-api-key}
# Compatibility alias used by some older code paths
# AZURE_OPENAI_KEY={your-api-key}

AZURE_OPENAI_DEPLOYMENT_NAME={your-deployment-name}
# Legacy compatibility name used by some docs/scripts
# AZURE_OPENAI_DEPLOYMENT={your-deployment-name}

AZURE_OPENAI_API_VERSION=2025-04-01-preview

AZURE_OPENAI_PRO_DEPLOYMENT_NAME={your-deployment-pro-name}
# Legacy compatibility name
# AZURE_DEPLOYMENT_PRO_NAME={your-deployment-pro-name}
AZURE_OPENAI_PRO_API_VERSION=2025-04-01-preview
AZURE_OPENAI_PRO_ENDPOINT=https://{your-custom-endpoint}.openai.azure.com/

AZURE_OPENAI_EMBEDDING_DEPLOYMENT={your-embedding-deployment-name}
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://{your-custom-endpoint}.openai.azure.com/openai/deployments/{your-embedding-deployment-name}/embeddings?api-version=2023-05-15

# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-service.search.windows.net
AZURE_SEARCH_API_KEY=your-api-key
AZURE_SEARCH_INDEX_NAME={name}-engineering-diagrams
# Legacy compatibility name
# AZURE_SEARCH_INDEX={name}-engineering-diagrams

# Azure Document Intelligence Configuration
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://{your-custom-endpoint}.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_API_KEY={your-api-key}

# Azure Blob Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName={your-account};AccountKey={your-key};EndpointSuffix=core.windows.net

# OR Managed Identity method (recommended for production in Azure)
# AZURE_STORAGE_ACCOUNT_URL=https://{your-account}.blob.core.windows.net
# AZURE_STORAGE_USE_MANAGED_IDENTITY=true

# Default containers
AZURE_STORAGE_INPUT_CONTAINER=engineering-diagrams
AZURE_STORAGE_OUTPUT_CONTAINER=edison-analysis-results
# Legacy compatibility name
# AZURE_STORAGE_CONTAINER_NAME=engineering-diagrams

# Optional performance settings
MAX_CONCURRENT_PAGES=5
ENABLE_SMART_CHUNKING=true

# Azure AI Projects / Code Agent configuration
AZURE_OPENAI_AGENT_PROJECT_ENDPOINT=https://{account}.services.ai.azure.com/api/projects/{project}
# Legacy compatibility name
# AZURE_PROJECT_ENDPOINT=https://{account}.services.ai.azure.com/api/projects/{project}
AZURE_OPENAI_AGENT_ID={your-agent-id}

# Azure AI Projects SDK uses token-based auth. API key is compatibility-only.
# AZURE_OPENAI_AGENT_API_KEY={your-agent-api-key}
AZURE_TENANT_ID={your-tenant-id}
# Optional service principal auth
# AZURE_CLIENT_ID={your-client-id}
# AZURE_CLIENT_SECRET={your-client-secret}
# Recommended for production in Azure
# AZURE_OPENAI_AGENT_USE_MANAGED_IDENTITY=true

# Native runtime controls
EDISON_RUNTIME_PROFILE=demo
EDISON_RUST_ENABLED=false
EDISON_RUST_FALLBACK_WORKERS=4

# Dynamic meta-agent default model
DYNAMIC_AGENT_MODEL=gpt-5-pro

# Bing Search Configuration (optional)
# IMPORTANT: This is a full Azure resource path, not just the connection name.
# Format:
# /subscriptions/{subscription_id}/resourceGroups/{resource_group}/providers/Microsoft.CognitiveServices/accounts/{ai_service}/projects/{project_name}/connections/{connection_name}
BING_CONNECTION_ID=